<?xml version="1.0" encoding="utf-8"?>
<!-- Native Android splash shown while the Flutter engine boots. Without
     a centred logo, users on slower phones see pure white for several
     seconds before runApp() fires and think the install failed. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/sakinah_splash_bg" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launcher_icon" />
    </item>
</layer-list>
