<?xml version="1.0" encoding="utf-8"?>
<!-- Native Android splash for API 21+. Branded logo prevents the
     "blank white screen" perception while Flutter engine boots. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/sakinah_splash_bg" />
    <item>
        <bitmap
            android:gravity="center"
            android:src="@mipmap/launcher_icon" />
    </item>
</layer-list>
